# Backend Environment Variables
# File: server/.env

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/emanagerit
# Or for MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/emanagerit?retryWrites=true&w=majority

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
